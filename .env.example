# Optional: pre-fill credentials so the app starts configured.
# If unset, the app will prompt for these on first launch via an in-app modal,
# and store the values in .likho_config.json (gitignored).
#
# At least one provider key is required to run OCR. The active provider
# is selected in the credentials modal (the gear icon).

# OpenAI (model: gpt-4o)
OPENAI_API_KEY=sk-...

# Anthropic Claude (model: claude-sonnet-4-6)
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (model: gemini-2.5-pro)
GEMINI_API_KEY=AIza...
