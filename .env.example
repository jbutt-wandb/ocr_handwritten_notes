# Optional: pre-fill these so the app starts configured.
# If unset, the app will prompt on first launch via an in-app modal,
# and write the values directly into your local .env (gitignored).

# Required: W&B credentials power both inference (W&B Inference) and Weave tracing.
WANDB_API_KEY=
ENTITY=
PROJECT=

# Optional: vision model used for OCR. One of:
#   moonshotai/Kimi-K2.5  (default, fastest)
#   google/gemma-4-31B-it
#   Qwen/Qwen3.5-35B-A3B
MODEL=
